# ──────────────────────────────────────────────
# AI Settings
# Set AI_PROVIDER explicitly, OR leave it unset
# and the app will auto-detect from whichever API
# key below is present (Gemini → Anthropic → OpenAI → OpenWeb).
# ──────────────────────────────────────────────

# AI_PROVIDER=gemini
# AI_PROVIDER=anthropic
# AI_PROVIDER=openai
# AI_PROVIDER=openweb
AI_PROVIDER=

# Optional: override the model. If unset, a sensible default is used per provider.
AI_MODEL=

# Google Gemini
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Open Web API (e.g. Open WebUI, Ollama, OpenRouter)
OPENWEB_API_BASE_URL=
OPENWEB_API_KEY=
